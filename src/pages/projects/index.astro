---
import { getCollection } from 'astro:content';
import '../../styles/global.css';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';

// 获取所有项目文章
const posts = await getCollection('posts');
const projectPosts = posts.filter(post => post.id.startsWith('projects/'));

// 按项目分组
const projects: Record<string, any[]> = {};
projectPosts.forEach(post => {
  const parts = post.id.split('/');
  if (parts.length >= 2) {
    const projectName = parts[1];
    if (!projects[projectName]) {
      projects[projectName] = [];
    }
    projects[projectName].push({
      ...post.data,
      url: `/posts/${post.id}/`,
      id: post.id,
    });
  }
});

// 项目名称映射
const projectNames: Record<string, string> = {
  '3DGS': '3D Gaussian Splatting',
};
---

<html lang="zh-cn">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>项目 - Acola</title>
	</head>
	<body>
		<Header />

		<main class="page-content">
			<h1>项目</h1>
			<p class="page-desc">我的项目文档与学习笔记。</p>

			<div class="projects-grid">
				{Object.keys(projects).map((projectKey) => {
					const projectDisplayName = projectNames[projectKey] || projectKey;
					const projectPosts = projects[projectKey];
					return (
						<div class="project-card">
							<h2 class="project-title">
								<a href={`/projects/${projectKey}/`}>{projectDisplayName}</a>
							</h2>
							<p class="project-count">{projectPosts.length} 篇文章</p>
							<ul class="project-list">
								{projectPosts.map((post) => (
									<li>
										<a href={post.url}>{post.title}</a>
										<span class="project-list-date"> - {new Date(post.pubDate).toLocaleDateString('zh-CN')}</span>
									</li>
								))}
							</ul>
						</div>
					);
				})}
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	h1 {
		margin-bottom: 0.5rem;
	}
	.page-desc {
		color: #666;
		margin-bottom: 2rem;
		text-align: center;
	}
	.projects-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
		gap: 2rem;
	}
	.project-card {
		background: #fff;
		border-radius: 12px;
		padding: 1.5rem;
		box-shadow: 0 2px 8px rgba(0,0,0,0.06);
	}
	.project-title {
		font-size: 1.5rem;
		margin: 0 0 0.5rem 0;
	}
	.project-title a {
		color: #333;
		text-decoration: none;
	}
	.project-title a:hover {
		color: #2563eb;
	}
	.project-count {
		color: #999;
		font-size: 0.85rem;
		margin-bottom: 1rem;
	}
	.project-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.project-list li {
		padding: 0.4rem 0;
		border-bottom: 1px dashed #eee;
	}
	.project-list li:last-child {
		border-bottom: none;
	}
	.project-list a {
		color: #000;
		text-decoration: none;
	}
	.project-list a:hover {
		text-decoration: underline;
	}
	.project-list-date {
		font-size: 0.85rem;
		color: #999;
	}
	
	@media (max-width: 720px) {
		.projects-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
