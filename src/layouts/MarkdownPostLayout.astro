---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
const { frontmatter } = Astro.props;
const { category, tags } = frontmatter;
---
<html lang="zh-cn">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{frontmatter.title}</title>
  </head>
  <body>
    <Header />
    <main class="page-content">
      <h1 class="post-title">{frontmatter.title}</h1>
      <div class="post-meta">
        {category && (
          <div class="post-category">
            <a href={`/categories/?cat=${category}`}>{category}</a>
          </div>
        )}
        {tags && tags.length > 0 && (
          <div class="post-tags">
            {tags.map((tag: string) => (
              <a href={`/tags/?tag=${tag}`} class="tag">{tag}</a>
            ))}
          </div>
        )}
      </div>
      <div class="post-content">
        <slot />
      </div>
      <div class="post-footer">
        {frontmatter.pubDate.toString().slice(0,10)}
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  .post-title {
    margin-bottom: 0.5rem;
  }
  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #eee;
  }
  .post-category a {
    display: inline-block;
    background: #e0e7ff;
    color: #3730a3;
    padding: 0.15rem 0.6rem;
    border-radius: 999px;
    font-size: 0.8rem;
    text-decoration: none;
    transition: background 0.2s;
  }
  .post-category a:hover {
    background: #c7d2fe;
  }
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }
  .tag {
    background: #fef3c7;
    color: #92400e;
    padding: 0.15rem 0.6rem;
    border-radius: 999px;
    font-size: 0.8rem;
    text-decoration: none;
    transition: background 0.2s;
  }
  .tag:hover {
    background: #fde68a;
  }
  .post-footer {
    font-size: 0.85rem;
    color: #999;
    text-align: right;
    margin-top: 3rem;
    padding-top: 1rem;
    border-top: 1px solid #eee;
  }
</style>
